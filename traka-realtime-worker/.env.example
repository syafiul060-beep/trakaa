# Samakan dengan traka-api (Upstash/Railway) — worker harus bisa SUBSCRIBE ke Redis yang sama.
REDIS_URL=redis://localhost:6379

PORT=3100

# CORS origin untuk Socket.IO (koma = beberapa). Produksi: https://app.traka.id
ALLOWED_ORIGINS=*

# Staging: secret statis (klien: TRAKA_REALTIME_SOCKET_TOKEN di build). Jangan untuk produksi publik.
# SOCKET_AUTH_DEV_SECRET=dev-only-secret

# Produksi (Tahap 4): samakan persis dengan traka-api REALTIME_WS_TICKET_SECRET (min 16 char).
# App Flutter memanggil POST /api/realtime/ws-ticket lalu connect dengan auth.token = ticket.
# REALTIME_WS_TICKET_SECRET=ubah-dengan-random-panjang-min-16
