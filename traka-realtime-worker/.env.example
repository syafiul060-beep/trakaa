# Samakan dengan traka-api (Upstash/Railway) — worker harus bisa SUBSCRIBE ke Redis yang sama.
REDIS_URL=redis://localhost:6379

PORT=3100

# CORS origin untuk Socket.IO (koma = beberapa). Produksi: https://app.traka.id
ALLOWED_ORIGINS=*

# Staging: jika diisi, klien harus kirim auth.token / query token yang sama (bukan untuk produksi).
# Produksi: ganti dengan validasi ticket JWT dari REST (traka-api).
# SOCKET_AUTH_DEV_SECRET=dev-only-secret
