# Salin file ini ke .env dan isi dengan config Firebase dari Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Traka API (hybrid — samakan dengan Flutter TRAKA_API_BASE_URL; lihat PRODUCTION_API_BASE_URL.txt di root monorepo)
VITE_TRAKA_API_BASE_URL=https://trakaa-production.up.railway.app
VITE_TRAKA_USE_HYBRID=true
# Deploy: di Railway (traka-api) set ALLOWED_ORIGINS agar mencakup origin hosting admin, mis. https://traka-admin.web.app — lihat traka-api/docs/RAILWAY_DEPLOY_CEPAT.md
