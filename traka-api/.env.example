# Copy ke .env dan isi nilai
PORT=3001

# CORS - WAJIB untuk produksi (jangan pakai *)
# Contoh: https://app.traka.id,https://admin.traka.id
ALLOWED_ORIGINS=https://app.traka.id,https://admin.traka.id

# Phase 1 Hybrid (driver_status) - WAJIB
REDIS_URL=redis://localhost:6379
# Upstash: redis://default:PASSWORD@HOST.upstash.io:6379
# Produksi: pastikan instance cukup (Upstash Pro/Redis Cloud 256MB+ untuk driver_status)

# Firebase Admin SDK - WAJIB (untuk auth driver)
# Opsi 1: Path ke file JSON (lokal)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Opsi 2: Isi JSON sebagai string (untuk Railway/Render)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Monitoring (Tahap 5) - OPSIONAL
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=development   # Override untuk dev lokal (supaya tidak alert production)

# PostgreSQL pool - produksi 1-5 jt pengguna (default 50)
# Lihat docs/SETUP_PG_POOL_PRODUCTION.md untuk Railway/Render/PM2/Docker
# PG_POOL_MAX=50

# Phase 2+ (orders/users) - OPSIONAL untuk Phase 1
# Lihat SETUP_DATABASE.md untuk panduan lengkap (Supabase)
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
