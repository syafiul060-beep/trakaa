# Node (tools / skrip lokal di root traka/, bukan Flutter pub)
node_modules/
/package.json
/package-lock.json

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Java heap dumps (JVM crash/debug files - jangan di-commit!)
*.hprof
**/*.hprof
/android/**/*.hprof

# iOS
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/Flutter.framework
/ios/Flutter/App.framework
/ios/Flutter/flutter_export_environment.sh
/ios/ServiceDefinitions.json

# Firebase config untuk track.html (copy dari firebase-config.example.js)
hosting/firebase-config.js
web/firebase-config.js

# iOS - file sensitif (JANGAN commit!)
ios/Runner/GoogleService-Info.plist
ios/Runner/Keys.plist

# Firebase config Flutter (berisi API keys - JANGAN commit!)
lib/firebase_options.dart

# Build output untuk hosting (build dari traka-admin)
hosting/admin/

# Firebase CLI (cache hosting / deploy; tidak perlu di-version)
.firebase/
