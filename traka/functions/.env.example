# Salin file ini ke .env dan isi nilai asli.
# .env JANGAN di-commit ke git (sudah di .gitignore).

# Email Gmail untuk kirim kode verifikasi OTP
GMAIL_EMAIL=your-email@gmail.com

# App Password dari https://myaccount.google.com/apppasswords
# Bukan password Gmail biasa. Wajib aktifkan 2-Step Verification dulu.
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
