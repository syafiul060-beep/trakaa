rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: cek apakah user login adalah admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- orders: integritas dokumen (selaras OrderService: travel vs kirim barang, auto-konfirmasi) ---
    function orderParticipantUidsUnchanged() {
      return request.resource.data.passengerUid == resource.data.passengerUid
        && request.resource.data.driverUid == resource.data.driverUid
        && request.resource.data.get('receiverUid', '') == resource.data.get('receiverUid', '');
    }

    function orderTypeUnchanged() {
      return request.resource.data.get('orderType', 'travel') == resource.data.get('orderType', 'travel');
    }

    // Kirim barang: tidak boleh set autoConfirmPickup / autoConfirmComplete (hanya travel lewat app + service).
    function kirimBarangNoAutoConfirmFlags() {
      return request.resource.data.get('orderType', 'travel') != 'kirim_barang'
        || (
          request.resource.data.get('autoConfirmPickup', false) != true
          && request.resource.data.get('autoConfirmComplete', false) != true
        );
    }

    function validNewOrderNoKirimAutoConfirm() {
      return request.resource.data.get('orderType', 'travel') != 'kirim_barang'
        || (
          request.resource.data.get('autoConfirmPickup', false) != true
          && request.resource.data.get('autoConfirmComplete', false) != true
        );
    }

    function orderUpdateIntegrity() {
      return orderParticipantUidsUnchanged()
        && orderTypeUnchanged()
        && kirimBarangNoAutoConfirmFlags();
    }

    // Field verifikasi admin — hanya admin boleh mengubah (kecuali user set submittedAt).
    function adminVerificationAdminKeysUnchangedForUser() {
      return request.resource.data.get('adminVerificationPendingAt', null)
          == resource.data.get('adminVerificationPendingAt', null)
        && request.resource.data.get('adminVerificationMessage', null)
          == resource.data.get('adminVerificationMessage', null)
        && request.resource.data.get('adminVerificationDeadlineAt', null)
          == resource.data.get('adminVerificationDeadlineAt', null)
        && request.resource.data.get('adminVerificationRestrictFeatures', null)
          == resource.data.get('adminVerificationRestrictFeatures', null);
    }

    // Data kendaraan di users: setelah tersimpan, hanya admin boleh ubah plat/merek/type/dll.
    // Driver boleh menambah field permintaan ubah (STNK) tetapi tidak boleh menghapus timestamp permintaan.
    function vehicleDataLocked(data) {
      return data.vehiclePlat != null || data.vehicleUpdatedAt != null;
    }

    function vehicleCoreFieldsUnchangedForUser() {
      return !vehicleDataLocked(resource.data)
        || (
          request.resource.data.vehiclePlat == resource.data.vehiclePlat
          && request.resource.data.vehicleMerek == resource.data.vehicleMerek
          && request.resource.data.vehicleType == resource.data.vehicleType
          && request.resource.data.vehicleJumlahPenumpang == resource.data.vehicleJumlahPenumpang
          && request.resource.data.vehicleUpdatedAt == resource.data.vehicleUpdatedAt
        );
    }

    // User tidak boleh menghapus vehicleChangeRequestAt (set ke null) setelah pernah mengirim.
    function vehicleChangeRequestNotClearedByUser() {
      return resource.data.vehicleChangeRequestAt == null
        || request.resource.data.vehicleChangeRequestAt != null;
    }

    function driverOwnVehicleLocked() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && vehicleDataLocked(
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        );
    }

    // Collection users: data profil (penumpang & driver, termasuk region/latitude/longitude)
    // Baca: hanya user login (cek email/phone via Cloud Function checkEmailExists/checkPhoneExists)
    // Tulis: user sendiri atau admin (untuk edit user dari panel admin)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null
        && (isAdmin()
          || (request.auth.uid == userId
            && adminVerificationAdminKeysUnchangedForUser()
            && vehicleCoreFieldsUnchangedForUser()
            && vehicleChangeRequestNotClearedByUser()));
      allow delete: if false;
      // verification_logs – audit trail verifikasi wajah (forensik)
      match /verification_logs/{logId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow update, delete: if false;
      }
    }

    // Collection verification_codes: kode verifikasi email (hanya Cloud Function akses)
    // Client memakai verifyRegistrationCode Cloud Function
    match /verification_codes/{email} {
      allow read, write: if false;
    }

    // device_accounts – cek via Cloud Function checkRegistrationAllowed
    // Baca: user login (account deletion). Tulis: user login (recordRegistration)
    match /device_accounts/{deviceId} {
      allow read: if request.auth != null
        && (resource.data.penumpangUid == request.auth.uid
            || resource.data.driverUid == request.auth.uid);
      allow create, update: if request.auth != null
        && (request.resource.data.penumpangUid == request.auth.uid
            || request.resource.data.driverUid == request.auth.uid);
      allow delete: if false;
    }

    // device_rate_limit – Tahap 3: dipindah ke Cloud Function (checkLoginRateLimit, recordLoginFailed, recordLoginSuccess).
    // Hanya Admin SDK di Cloud Function yang boleh akses. Client tidak lagi baca/tulis langsung.
    match /device_rate_limit/{deviceId} {
      allow read, write: if false;
    }

    // driver_status – status dan lokasi driver yang sedang aktif (siap kerja dengan rute)
    match /driver_status/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // driver_schedules – jadwal keberangkatan driver (tujuan awal/akhir, jam, tanggal)
    // Baca: semua user login (penumpang butuh lihat jadwal tersedia). Tulis: hanya pemilik doc.
    match /driver_schedules/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // trips – riwayat perjalanan driver (rute yang sudah selesai)
    match /trips/{tripId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.driverUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.driverUid == request.auth.uid || isAdmin());
    }

    // route_sessions – sesi rute perjalanan driver (untuk Riwayat Rute di Data Order)
    // Disimpan saat driver klik Berhenti Kerja / Selesai Bekerja.
    match /route_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.driverUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.driverUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.driverUid == request.auth.uid;
    }

    // orders – pesanan penumpang (nomor pesanan unik, riwayat travel)
    // Create: hanya sebagai penumpang (passengerUid = uid). Update: peserta + integritas field inti + blok autoConfirm untuk kirim_barang.
    // Catatan: validasi transisi status/jarak tetap di app + idealnya Cloud Functions untuk hardening penuh.
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.passengerUid == request.auth.uid
        && validNewOrderNoKirimAutoConfirm();
      allow update: if request.auth != null
        && (isAdmin()
            || (
              orderUpdateIntegrity()
              && (resource.data.driverUid == request.auth.uid
                  || resource.data.passengerUid == request.auth.uid
                  || resource.data.get('receiverUid', '') == request.auth.uid)
            ));
      allow delete: if request.auth != null
        && (resource.data.driverUid == request.auth.uid
            || resource.data.passengerUid == request.auth.uid
            || resource.data.get('receiverUid', '') == request.auth.uid
            || isAdmin());
      // Subcollection messages: driver, penumpang, penerima (kirim barang), atau admin
      match /messages/{messageId} {
        allow read, create, update: if request.auth != null
          && (get(/databases/$(database)/documents/orders/$(orderId)).data.passengerUid == request.auth.uid
              || get(/databases/$(database)/documents/orders/$(orderId)).data.driverUid == request.auth.uid
              || get(/databases/$(database)/documents/orders/$(orderId)).data.get('receiverUid', '') == request.auth.uid
              || isAdmin());
        allow delete: if request.auth != null
          && (get(/databases/$(database)/documents/orders/$(orderId)).data.passengerUid == request.auth.uid
              || get(/databases/$(database)/documents/orders/$(orderId)).data.driverUid == request.auth.uid
              || get(/databases/$(database)/documents/orders/$(orderId)).data.get('receiverUid', '') == request.auth.uid
              || isAdmin());
      }
    }

    // counters – hanya Cloud Function (Admin SDK) yang tulis. Client baca untuk fallback; tulis via callable.
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // vehicles – data kendaraan driver (nomor plat, merek, type, jumlah penumpang)
    match /vehicles/{vehicleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.driverUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (isAdmin()
          || (resource.data.driverUid == request.auth.uid && !driverOwnVehicleLocked()));
    }

    // vehicle_brands – data merek dan type mobil. Hanya admin yang boleh edit.
    match /vehicle_brands/{brandId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // vehicle_data – data kendaraan per driver (fallback kapasitas). Penumpang baca saat cari driver.
    match /vehicle_data/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // driver_transfers – oper penumpang dari driver pertama ke driver kedua
    match /driver_transfers/{transferId} {
      allow read: if request.auth != null
        && (resource.data.fromDriverUid == request.auth.uid || resource.data.toDriverUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromDriverUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.fromDriverUid == request.auth.uid || resource.data.toDriverUid == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.fromDriverUid == request.auth.uid || resource.data.toDriverUid == request.auth.uid);
    }

    // app_config – konfigurasi aplikasi (tarif, kontak admin). Baca: user login. Tulis: admin.
    // maintenance, min_version, settings: baca tanpa auth (app cek saat startup sebelum login)
    match /app_config/{docId} {
      allow read: if request.auth != null || docId == 'maintenance' || docId == 'min_version' || docId == 'settings';
      allow write: if isAdmin();
    }

    // contribution_payments – riwayat pembayaran kontribusi driver (Cloud Function tulis).
    // Driver baca record sendiri (Pendapatan & Potongan, Riwayat Pembayaran)
    match /contribution_payments/{paymentId} {
      allow read: if request.auth != null
        && (resource.data.driverUid == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // violation_records – pelanggaran (tidak scan barcode). Dibuat oleh app saat konfirmasi otomatis.
    // User baca record sendiri (untuk Riwayat Pembayaran). Admin baca semua. Cloud Function update paidAt (bypass rules).
    match /violation_records/{recordId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // voice_calls – panggilan suara in-app (signaling WebRTC)
    // Hanya caller/callee (penumpang atau driver order) boleh baca/tulis
    match /voice_calls/{orderId} {
      allow read, write: if request.auth != null
        && (resource == null
            || resource.data.callerUid == request.auth.uid
            || resource.data.calleeUid == request.auth.uid
            || request.resource.data.callerUid == request.auth.uid
            || request.resource.data.calleeUid == request.auth.uid);
      match /ice/{candidateId} {
        allow read, write: if request.auth != null;
      }
    }

    // sos_events – log SOS/darurat (penumpang atau driver). User create untuk diri sendiri. Admin baca semua.
    match /sos_events/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // track_share_links – link bagikan lacak ke keluarga. Token = docId (rahasia).
    // Create: travel = penumpang pemesan; kirim_barang = pengirim (passengerUid) atau penerima (receiverUid).
    // Read: siapa saja (token di URL = rahasia).
    match /track_share_links/{token} {
      allow create: if request.auth != null
        && (
          (request.resource.data.orderType == 'travel'
            && request.resource.data.passengerUid == request.auth.uid)
          || (request.resource.data.orderType == 'kirim_barang'
            && request.resource.data.passengerUid == request.auth.uid)
          || (request.resource.data.orderType == 'kirim_barang'
            && request.resource.data.get('receiverUid', '') != ''
            && request.resource.data.receiverUid == request.auth.uid)
        );
      allow read: if true;
      allow update, delete: if false;
    }

    // admin_chats – chat user dengan admin (1:1 per user)
    // Status: bot | in_queue | connected | closed. User: akses chat sendiri. Admin: akses semua.
    match /admin_chats/{userId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isAdmin());
      }
    }

    // admin_status – status admin (online/offline/busy) untuk live chat support
    // Baca: user login perlu cek admin online saat klik "Hubungi Admin"
    // Tulis: admin (set online/offline), atau user saat sambungkan ke admin (set busy + currentChatUserId)
    match /admin_status/{adminId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isAdmin();
      allow update: if request.auth != null && (
        isAdmin()
        || (
          resource.data.get('status', '') == 'online'
          && (!('currentChatUserId' in resource.data) || resource.data.currentChatUserId == null || resource.data.currentChatUserId == '')
          && request.resource.data.get('status', '') == 'busy'
          && request.resource.data.get('currentChatUserId', '') == request.auth.uid
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // promotions – konten promosi/iklan untuk dibaca driver dan penumpang
    match /promotions/{promoId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // admin_notifications – riwayat alert (konfirmasi kirim data, STNK, dll.). Tulis hanya Admin SDK (Functions).
    match /admin_notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // admin_audit_logs – log aksi admin. Create: admin. Read: admin.
    match /admin_audit_logs/{logId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // scan_audit_log – audit scan barcode (pickup, complete, receiver). Hanya Cloud Function tulis. Admin baca untuk investigasi.
    match /scan_audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // app_feedback – saran & masukan dari pengguna. Create: user login (app) atau admin (manual). Read: admin.
    match /app_feedback/{feedbackId} {
      allow create: if request.auth != null
        && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

  }
}
