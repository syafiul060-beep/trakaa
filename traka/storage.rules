rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: cek apakah user adalah peserta order (penumpang, driver, atau penerima)
    function isOrderParticipant(orderId) {
      let order = firestore.get(/databases/(default)/documents/orders/$(orderId)).data;
      return request.auth != null
        && (order.passengerUid == request.auth.uid
            || order.driverUid == request.auth.uid
            || order.get('receiverUid', '') == request.auth.uid);
    }

    // Chat audio: hanya peserta order yang boleh upload/download
    match /chat_audio/{orderId}/{fileName} {
      allow read, write: if isOrderParticipant(orderId);
    }

    // Chat images: hanya peserta order yang boleh upload/download
    match /chat_images/{orderId}/{fileName} {
      allow read, write: if isOrderParticipant(orderId);
    }

    // Chat videos: hanya peserta order yang boleh upload/download
    match /chat_videos/{orderId}/{fileName} {
      allow read, write: if isOrderParticipant(orderId);
    }
    
    // User photos: hanya pemilik yang boleh upload, semua user login boleh baca
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
